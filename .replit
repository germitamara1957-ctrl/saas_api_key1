modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "gce"
run = ["sh", "-c", "test"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 5000

[[ports]]
localPort = 23183
externalPort = 3000

[[ports]]
localPort = 23184
externalPort = 3001

[[ports]]
localPort = 23185
externalPort = 4200

[userenv]

[userenv.shared]
SCRYPT_N = "16384"
SMTP_HOST = " smtp.gmail.com"
SMTP_USER = "lt500950@gmail.com"
SMTP_FROM = "AI Gateway lt500950@gmail.com"
SMTP_PORT = "587"

[nix]
channel = "stable-25_05"
